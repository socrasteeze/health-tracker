# Copy to .env and fill in. Consumed by docker-compose.yml.
#
# Generate the two VAPID keys once with:
#   node scripts/generate-keys.js
# (or the dockerized one-liner in DEPLOY.md), then paste them below.

# Web push (VAPID) — required for reminders/alerts. If unset, push is disabled
# and the app still logs data; the UI shows "reminders aren't set up".
VAPID_PUBLIC=
VAPID_PRIVATE=
VAPID_SUBJECT=mailto:you@yourdomain.com

# Public HTTPS origin the PWA is served from (Cloudflare Tunnel hostname).
# Used by scripts/add-user.js to print magic-link URLs.
PUBLIC_URL=https://health.yourdomain.com
